        "base-unix",
        "arch-x86_64",
        "ocaml",
        "base-domains",
        "flexdll",
        "system-mingw",
        "base-bigarray",
        "ocaml-options-vanilla",
        "base-unix",
        "mingw-w64-shims"
      ],
      "version": "5.1.1",
      "install": "make \"install\"",
      "build": "[\r\n  \"./configure\"\r\n  \"--host=x86_64-w64-mingw32\"\r\n    {os-distribution = \"cygwin\" & system-mingw:installed &\r\n     arch-x86_64:installed}\r\n  \"--host=i686-w64-mingw32\"\r\n    {os-distribution = \"cygwin\" & system-mingw:installed &\r\n     arch-x86_32:installed}\r\n  \"--prefix=%{prefix}%\"\r\n  \"--docdir=%{doc}%/ocaml\"\r\n  \"--with-flexdll=%{flexdll:share}%\" {os = \"win32\" & flexdll:installed}\r\n  \"-C\"\r\n  \"CC=cc\" {os = \"openbsd\" | os = \"macos\"}\r\n  \"ASPP=cc -c\" {os = \"openbsd\" | os = \"macos\"}\r\n]\r\n[make \"-j%{jobs}%\"]",
      "source": {
        "url": "https://github.com/ocaml/ocaml/archive/5.1.1.tar.gz",
        "size": 5771148,
