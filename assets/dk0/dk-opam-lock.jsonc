      "install": "[make \"install\"] {os = \"win32\"}\r\n[\"mkdir\" \"-p\" \"%{lib}%/ocamlbuild\"] {os = \"win32\"}\r\n[\"install\" \"-m\" \"0644\" \"META\" \"%{lib}%/ocamlbuild\"] {os = \"win32\"}",
