      ],
      "version": "3.19.1",
      "install": null,
      "build": "[\"ocaml\" \"boot/bootstrap.ml\" \"-j\" jobs]\r\n[\r\n  \"./_boot/dune.exe\"\r\n  \"build\"\r\n  \"dune.install\"\r\n  \"--release\"\r\n  \"--profile\"\r\n  \"dune-bootstrap\"\r\n  \"-j\"\r\n  jobs\r\n]",
      "source": {
        "url": "https://github.com/ocaml/dune/releases/download/3.19.1/dune-3.19.1.tbz",
        "size": 2311564,
        "archive": "tbz",
        "checksums": [
          "sha256=a10386f980cda9417d1465466bed50dd2aef9c93b9d06a0f7feeedb0a1541158",
